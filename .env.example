DEBUG=1
SECRET_KEY=REPLACE_ME!
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://*.ngrok-free.app,https://*.ngrok.io

# Optional: PostgreSQL (Aiven, Supabase, dll). Kosongkan = pakai SQLite.
# Aiven: Overview service → Connection info (SSL wajib, sudah di-handle apps)
# Password kalau ada @ # dll → URL-encode dulu
# DATABASE_URL=postgresql://avnadmin:YOUR_PASSWORD@HOST.aivencloud.com:PORT/defaultdb
#
# Contoh bentuk (ganti HOST, PORT, password):
# DATABASE_URL=postgresql://avnadmin:xxxx@pg-xxxx.k.aivencloud.com:27255/defaultdb
#
# WSL2 + IPv6 unreachable: DATABASE_FORCE_IPV4=1 (default)
# DATABASE_FORCE_IPV4=0